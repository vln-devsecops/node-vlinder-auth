{
  "name": "@vln-devsecops/auth-lambda",
  "license": "MIT",
  "version": "1.0.0",
  "type": "module",
  "description": "Lambda handler source for cognito_auth module (post-confirmation, pre-token-generation, admin-api).",
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && node esbuild.config.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.699.0",
    "@aws-sdk/client-dynamodb": "^3.699.0",
    "@aws-sdk/lib-dynamodb": "^3.699.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.146",
    "@types/node": "^22.15.23",
    "@vitest/coverage-v8": "^3.1.1",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.25.12",
    "typescript": "~5.7.2",
    "vitest": "^3.1.1"
  }
}
